{
  "name": "Marp Presentations",
  "image": "mcr.microsoft.com/devcontainers/node:20",
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "marp-team.marp-vscode"
      ],
      "settings": {
        "editor.wordWrap": "on",
        "[markdown]": {
          "editor.formatOnSave": false
        }
      }
    }
  }
}
