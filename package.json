{
  "name": "marp-presentations",
  "version": "1.0.0",
  "description": "Marp-based presentation template with Codespace support",
  "scripts": {
    "build": "mkdir -p output && marp presentations/*.md --output output/",
    "build:pdf": "mkdir -p output && marp presentations/*.md --output output/ --pdf --allow-local-files",
    "build:pptx": "mkdir -p output && marp presentations/*.md --output output/ --pptx",
    "build:all": "npm run build && npm run build:pdf && npm run build:pptx",
    "watch": "marp presentations/*.md --watch --output output/",
    "preview": "marp presentations/*.md --preview --watch"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^3.4.0"
  }
}